# ─── SecureCorp Server Environment ───
# Copy this file to .env and update with your PostgreSQL credentials.
#
# In a real production environment:
#   - Use strong, unique passwords
#   - Never commit .env files to version control
#   - Use environment-specific secrets management (e.g., AWS Secrets Manager, Vault)
#   - SESSION_SECRET should be a long random string (e.g., 64+ chars)
#
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=securecorp
DB_HOST=localhost
DB_PORT=5432
SESSION_SECRET=securecorp-demo-secret-change-in-production
